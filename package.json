{
  "name": "react-sc-popup",
  "description": "A simple and composable popup component with fluent interactions.",
  "author": "Brandon Leon<https://github.com/Brandon-Ln",
  "version": "0.0.1",
  "keywords": [
    "React",
    "component",
    "popup",
    "popper",
    "modal",
    "dialog"
  ],
  "homepage": "https://github.com/Brandon-Ln/react-sc-popup",
  "sideEffects": [],
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "browser": {
        "production": "./dist/index.umd.js"
      },
      "import": "./dist/index.es.js"
    }
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.(j|t)s?(x)": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "vite",
    "commit": "cz",
    "prepare": "husky install",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && tsc --emitDeclarationOnly",
    "lint:fix": "eslint ./src --ext .jsx,.js,.ts,.tsx --quiet --fix --ignore-path ./.gitignore",
    "release": "vite build && tsc && release-it"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "peerDependencies": {
    "react": "^16.8.0  || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.8.0  || ^17.0.0 || ^18.0.0"
  },
  "dependencies": {
    "@react-spring/web": "^9.0.0",
    "@use-gesture/react": "^10.0.0",
    "classnames": "^2.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.1",
    "@commitlint/cz-commitlint": "^18.6.1",
    "@types/node": "^20.9.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^1.3.0",
    "commitizen": "^4.3.2",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.0",
    "inquirer": "^8.2.7",
    "jsdom": "^20.0.0",
    "postcss-preset-env": "^7.7.2",
    "postcss-scss": "^4.0.4",
    "prettier": "2.7.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-test-renderer": "^18.2.0",
    "release-it": "^18.1.2",
    "sass": "^1.53.0",
    "typescript": "^5.0.0",
    "vite": "^3.1.8",
    "vite-plugin-eslint": "^1.6.1"
  }
}
